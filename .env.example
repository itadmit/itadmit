# העתק ל-.env ומלא (הקובץ .env לא נכנס לגיט)

# Neon — רק ה-URI, לדוגמה:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
#
# לא להדביק את פקודת psql מהמסוף (בלי psql, בלי מרכאות סביב ה-URL).
# אם יש בעיית חיבור, השאר sslmode=require בלבד (בלי channel_binding).
#
# npm run db:init-neon קורא את הקובץ הזה אוטומטית (dotenv).
DATABASE_URL=

# Resend — התראות מייל על ליד חדש (אופציונלי; בלי המפתח פשוט לא נשלח מייל)
RESEND_API_KEY=
# כתובת השולח המופיעה במייל. חייב להיות דומיין מאומת בחשבון ה-Resend.
EMAIL_FROM="תדמית אינטראקטיב <noreply@itadmit.co.il>"
# לאן לשלוח את ההתראה על ליד חדש
LEAD_NOTIFY_EMAIL=itadmit@gmail.com

# Google Analytics (אופציונלי — אם לא מוגדר, GA לא נטען)
NEXT_PUBLIC_GA_ID=
